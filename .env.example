# Supabase - valeurs a renseigner localement et dans Vercel
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_CONTACTS_TABLE=contacts

# Notifications transactionnelles
EMAIL_PROVIDER=brevo
BREVO_API_KEY=
TVF_EMAIL_FROM=Territoires Vivants France <contact@territoiresvivantsfrance.fr>
TVF_EMAIL_REPLY_TO=contact@territoiresvivantsfrance.fr
TVF_NOTIFICATION_EMAIL=contact@territoiresvivantsfrance.fr
TVF_OUTBOUND_TIMEOUT_MS=9000

# Acces TVF OS - generer une valeur longue et aleatoire
TVF_ADMIN_TOKEN=

# Integrations optionnelles, a laisser vides tant qu'elles ne sont pas activees
OPENAI_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Limitation anti-abus par instance serveur
TVF_ADMIN_LOGIN_LIMIT=8
TVF_ADMIN_LOGIN_WINDOW_MS=900000
TVF_CONTACT_RATE_LIMIT=8
TVF_CONTACT_RATE_WINDOW_MS=600000
