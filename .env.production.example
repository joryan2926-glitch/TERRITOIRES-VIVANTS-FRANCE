# Exemple de variables de production Vercel pour TVF
# Ne jamais commiter les vraies cles.

SUPABASE_URL=https://votre-projet.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<CLE_SERVICE_ROLE_SUPABASE>
SUPABASE_ANON_KEY=<CLE_PUBLIQUE_SUPABASE>
SUPABASE_CONTACTS_TABLE=contacts

EMAIL_PROVIDER=brevo
BREVO_API_KEY=<CLE_API_BREVO>
TVF_EMAIL_FROM=Territoires Vivants France <contact@territoiresvivantsfrance.fr>
TVF_EMAIL_REPLY_TO=contact@territoiresvivantsfrance.fr
TVF_NOTIFICATION_EMAIL=contact@territoiresvivantsfrance.fr
TVF_OUTBOUND_TIMEOUT_MS=9000

# Back-office demandes
TVF_ADMIN_TOKEN=<TOKEN_ADMIN_LONG_A_CHOISIR>

# TVF OS Dashboard
# Reutilise TVF_ADMIN_TOKEN, SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY et SUPABASE_CONTACTS_TABLE.
