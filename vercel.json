{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(self), microphone=(), geolocation=(self), payment=()"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/signalements",
      "destination": "/api/signalements"
    },
    {
      "source": "/materiaux",
      "destination": "/api/materiaux"
    },
    {
      "source": "/projets",
      "destination": "/api/projets"
    },
    {
      "source": "/territoires",
      "destination": "/api/territoires"
    },
    {
      "source": "/biens-candidats",
      "destination": "/api/biens-candidats"
    },
    {
      "source": "/investisseurs",
      "destination": "/api/investisseurs"
    },
    {
      "source": "/mecenes",
      "destination": "/api/mecenes"
    }
  ],
  "redirects": []
}
